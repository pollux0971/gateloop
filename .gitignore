node_modules/
dist/
*.tsbuildinfo
workspaces/*
!workspaces/.gitkeep
artifacts/*
!artifacts/.gitkeep
.env
*.log
# Codex account binding (per-developer, machine-local; never commit). Token itself
# lives in ~/.codex/auth.json (also gitignored at repo root).
/config.json
# Compiled output in package sources — every package exports ./src/index.ts and runs
# directly under `node --experimental-strip-types`; the emitted .js/.d.ts/.js.map are build noise.
packages/*/src/*.js
packages/*/src/*.js.map
packages/*/src/*.d.ts

# also ignore nested compiled output (shadows .ts under vite); single-level above covers current
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts

# Fixture run output (test artifacts) + build-side eval planning — never commit
.gateloop-fixture-out/
builder/planning/eval_idea_*.md

# CodeGraph index (EPIC-CW) — harness state, NOT agent output / not a tracked artifact.
# Excluded here (product repo) and via each disposable workspace's .git/info/exclude, so the
# index never leaks into a git diff / the exit-gate diff / the agent write-set.
.codegraph/
