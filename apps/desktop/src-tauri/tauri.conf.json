{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "gateloop-console",
  "version": "0.1.0",
  "identifier": "dev.gateloop.console",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "node -e \"require('fs').mkdirSync('dist',{recursive:true});require('fs').copyFileSync('../web/public/console.html','dist/index.html')\"",
    "beforeDevCommand": "node -e \"require('fs').mkdirSync('dist',{recursive:true});require('fs').copyFileSync('../web/public/console.html','dist/index.html')\""
  },
  "app": {
    "windows": [
      {
        "title": "GateLoop Console",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#121216"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
