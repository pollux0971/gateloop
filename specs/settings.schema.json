{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GateLoopSettings",
  "description": "User-tunable settings (VSCode-style). Global gates are NOT representable here.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "project_type": { "enum": ["greenfield", "brownfield", "patch"] },
        "stack":        { "enum": ["node-ts", "python", "go", "rust", "unknown"] }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "real_provider_scope": { "enum": ["none", "hybrid", "all"] }
      }
    },
    "parallelism": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_parallel_stories":     { "type": "integer", "minimum": 1, "maximum": 8 },
        "enable_competitive_debug": { "type": "boolean" }
      }
    },
    "quality_bar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "greenfield": {
          "type": "array",
          "items": { "enum": ["build", "test", "typecheck", "coverage"] }
        },
        "brownfield_strictness": { "enum": ["zero_new_failures", "full_bar"] }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_calls_per_story":  { "type": "integer", "minimum": 1,    "maximum": 200     },
        "max_tokens_per_story": { "type": "integer", "minimum": 1000, "maximum": 2000000 },
        "max_calls_per_run":    { "type": "integer", "minimum": 1,    "maximum": 5000    }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "promotion_target":     { "enum": ["local_stable", "git_remote", "artifact_registry"] },
        "human_gate_interface": { "enum": ["cli", "web", "none"] }
      }
    },
    "failure_bank": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scope": { "enum": ["project", "global"] }
      }
    },
    "brownfield": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recovery_depth": { "enum": ["shallow", "full"] }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trigger":         { "enum": ["on_second_failure", "on_every_failure", "off", "on_cycle_complete"] },
        "cross_model":     { "type": "boolean" },
        "max_directions":  { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    }
  }
}
