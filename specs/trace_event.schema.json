{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TraceEvent",
  "type": "object",
  "$defs": {
    "unknown_event_rule": {
      "description": "An event with a type not in this enum MUST be rendered as a flagged raw line, never silently dropped."
    }
  },
  "required": [
    "event_id",
    "run_id",
    "type",
    "timestamp"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "type": {
      "enum": [
        "idea_event",
        "planning_event",
        "context_packet_event",
        "agent_output_event",
        "tool_request_event",
        "permission_decision_event",
        "execution_event",
        "validation_event",
        "approval_event",
        "promotion_event",
        "rollback_event",
        "reasoning_event",
        "tool_call_event",
        "dispatch_event",
        "gateway_event",
        "validator_event",
        "workspace_event",
        "story_manager_event"
      ]
    },
    "timestamp": {
      "type": "string"
    },
    "agent_role": {
      "type": "string"
    },
    "pane_renderable": {
      "type": "boolean"
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "payload": {
      "type": "object"
    }
  }
}
