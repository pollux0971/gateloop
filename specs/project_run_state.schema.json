{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectRunState",
  "description": "Per-target-project run state. A fresh harness session reads this to resume from the last checkpoint. Mirrors builder/tracker/tracker_state.json semantics at product level.",
  "type": "object",
  "required": ["schema_version", "project_id", "run_id", "created_at", "updated_at",
               "current_story", "iterations_used", "run_iteration_budget", "stories"],
  "properties": {
    "schema_version":       { "type": "integer", "minimum": 1 },
    "project_id":           { "type": "string" },
    "run_id":               { "type": "string" },
    "created_at":           { "type": "string", "format": "date-time" },
    "updated_at":           { "type": "string", "format": "date-time" },
    "current_story":        { "type": ["string", "null"] },
    "last_decision":        { "type": ["string", "null"] },
    "iterations_used":      { "type": "integer", "minimum": 0 },
    "run_iteration_budget": { "type": "integer", "minimum": 1 },
    "stories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["story_id", "status", "attempts", "attempt_budget"],
        "properties": {
          "story_id":        { "type": "string" },
          "status":          { "enum": ["todo","in_progress","validating","debugging",
                                        "passed","checkpointed","blocked","escalated","done"] },
          "attempts":        { "type": "integer", "minimum": 0 },
          "attempt_budget":  { "type": "integer", "minimum": 1 },
          "checkpoint_sha":  { "type": ["string", "null"] },
          "last_action":     { "type": ["string", "null"] },
          "last_result":     { "type": ["string", "null"] },
          "blocked_reason":  { "type": ["string", "null"] }
        }
      }
    }
  }
}
