{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecretHandle",
  "description": "Formal schema for a secret handle entry. The raw secret value NEVER appears here or in any trace event.",
  "type": "object",
  "required": ["handle_id", "handle_type", "scope_boundary", "rotation_trigger", "audit_trail"],
  "additionalProperties": false,
  "properties": {

    "handle_id": {
      "type": "string",
      "description": "Unique identifier, e.g. 'provider.anthropic.default'"
    },

    "handle_type": {
      "enum": ["api_key", "oauth_token", "env_var"],
      "description": "Classification of the credential being brokered"
    },

    "scope_boundary": {
      "type": "object",
      "description": "Which stories and agents may request this handle",
      "required": ["allowed_story_patterns", "allowed_agent_roles"],
      "additionalProperties": false,
      "properties": {
        "allowed_story_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for story_ids that may use this handle. '*' = any."
        },
        "allowed_agent_roles": {
          "type": "array",
          "items": {
            "enum": ["planning_steward", "supervisor", "developer", "debugger", "reviewer"]
          }
        }
      }
    },

    "rotation_trigger": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["human", "ttl"] },
        "ttl_seconds": {
          "type": ["integer", "null"],
          "description": "TTL in seconds. Only used when kind=ttl. Actual rotation is outside the sandbox."
        }
      }
    },

    "audit_trail": {
      "type": "object",
      "description": "Configuration for audit logging. Values are NEVER logged — only access metadata.",
      "required": ["enabled", "log_fields"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "log_fields": {
          "type": "array",
          "items": {
            "enum": ["story_id", "agent_role", "timestamp", "result"]
          },
          "description": "Fields logged per access event. 'value' is NOT an allowed field."
        }
      }
    },

    "approval": {
      "type": ["string", "null"],
      "enum": ["human_login", "first_enable_only", "required", "auto", null]
    },

    "purpose": {
      "type": ["string", "null"]
    }
  }
}
